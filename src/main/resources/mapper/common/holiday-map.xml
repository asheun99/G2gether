<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yedam.app.common.mapper.HolidayMapper">
	<select id="selectHolidyList" resultType="HolidayVO">
		SELECT seq,
		       dt,
		       week_nm,
		       holi_nm,
		       use_yn
		FROM holiday
		ORDER BY dt
	</select>
</mapper>